{
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "pair_whitelist": ["WLD/USDT:USDT"],
        "ccxt_config": {
            "enableRateLimit": true,
            "options": {
                "defaultType": "swap",
                "createMarketBuyOrderRequiresPrice": false
            }
        },
        "ccxt_extra_config": {
            "options": {
                "defaultType": "swap"
            }
        },
        "pair_blacklist": []
    },
    "pairlists": [
        {"method": "StaticPairList"}
    ],
    "order_types": {
        "entry": "limit",
        "exit": "limit",
        "emergency_exit": "market",
        "stoploss": "market",
        "stoploss_on_exchange": false,
        "entry_params": {
            "postOnly": true
        },
        "exit_params": {
            "postOnly": true
        }
    },
    "entry_pricing": {
        "price_side": "bid",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false
        }
    },
    "exit_pricing": {
        "price_side": "ask",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0
    },
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "dry_run_wallet": 10000,
    "use_exit_signal": true,
    "exit_profit_only": false,
    "ignore_roi_if_entry_signal": false,
    "trailing_stop": true,
    "unfilledtimeout": {
        "entry": 30,
        "exit": 10,
        "exit_timeout_count": 3,
        "unit": "minutes"
    },
    "timeframe": "15m",
    "fiat_display_currency": "USD",
    "strategy": "MultiPairAdaptiveStrategy",
    "strategy_path": "user_data/strategies",
    "max_open_trades": 1,
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "db_url": "sqlite:///user_data/backtest_results/trades_wld.sqlite",
    "export": "trades",
    "disable_dataframe_checks": false
}
